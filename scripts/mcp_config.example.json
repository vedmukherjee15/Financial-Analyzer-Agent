{
  "google-sheets": {
    "command": "uvx",
    "args": ["mcp-google-sheets@latest"],
    "env": {
      "CREDENTIALS_PATH": "/absolute/path/to/gcp-oauth.keys.json",
      "TOKEN_PATH": "/absolute/path/to/token.json"
    },
    "transport": "stdio"
  },
  "yahoo-finance": {
    "command": "uvx",
    "args": ["yahoo-finance-mcp-server"],
    "transport": "stdio"
  }
}
